{
  "prompt": "Review this PR for performance regressions and post inline comments",
  "flow": "github-pr-review",
  "agents": [
    "github-specialist",
    "performance-engineer",
    "quality-director",
    "reporter"
  ],
  "tools": [
    "github-api",
    "github-pr-search",
    "lighthouse-ci"
  ],
  "skills": [
    "github-api-usage",
    "web-performance",
    "git-workflow"
  ],
  "expected_output_shape": {
    "type": "object",
    "required": [
      "summary",
      "activated_agents",
      "artifacts",
      "quality_gates",
      "next_actions"
    ]
  },
  "quality_gates": [
    "all referenced agents exist",
    "all referenced tools exist or have planned fallback",
    "reporter produces final aggregation",
    "quality-director reviews before final delivery"
  ]
}