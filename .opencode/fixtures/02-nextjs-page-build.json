    "react-specialist",
    "ui-designer",
    "performance-engineer",
    "testing-frontend",
    "quality-director",
    "reporter"
  ],
  "tools": [
    "lighthouse-ci",
    "lighthouse-runner"
  ],
  "skills": [
    "react-19-patterns",
    "nextjs-app-router",
    "web-performance",
    "testing-strategy"
  ],
  "expected_output_shape": {
