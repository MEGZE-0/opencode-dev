{
  "$schema": "https://nexusflow.ai/config.json",
  "default_agent": "project-manager",
  "provider": {},
  "permission": {},
  "mcp": {},
  "experimental": {
    "auto_task_routing": true,
  },
  "auto_triggers": [
    {
      "id": "git-commit",
      "condition": { "or": [{ "keywords": ["commit this", "git commit", "push this", "commit and push"] }, { "event": "staged_changes_detected" }] },
      "action": { "command": "commit" },
      "scope": "conversation",
      "priority": 9,
      "cooldown_seconds": 30,
    },
    {
      "id": "changelog-gen",
      "condition": { "or": [{ "keywords": ["changelog", "release notes", "what changed", "version bump"] }] },
      "action": { "command": "changelog" },
      "scope": "conversation",
      "priority": 7,
      "cooldown_seconds": 60,
    },
    {
      "id": "github-issue-opened",
      "condition": { "event": "github_issue_opened" },
      "action": { "flow": "github-issue-triage" },
      "scope": "workspace",
      "priority": 10,
      "cooldown_seconds": 0,
    },
    {
      "id": "github-pr-opened",
      "condition": { "event": "github_pr_opened" },
      "action": { "flow": "github-pr-review" },
      "scope": "workspace",
      "priority": 10,
      "cooldown_seconds": 0,
    },
    {
      "id": "docs-pr-translation",
      "condition": { "or": [{ "file_glob": "**/*.md" }, { "keywords": ["docs changed", "translate docs"] }] },
      "action": { "command": "translate" },
      "scope": "workspace",
      "priority": 7,
      "cooldown_seconds": 120,
    },
    {
      "id": "deploy-intent",
      "condition": { "or": [{ "keywords": ["deploy", "push to prod", "going live", "ship this", "release"] }] },
      "action": { "command": "deploy-check" },
      "scope": "conversation",
      "priority": 10,
      "cooldown_seconds": 120,
    },
    {
      "id": "seo-work",
      "condition": { "or": [{ "keywords": ["seo", "ranking", "search visibility", "organic traffic", "keywords"] }] },
      "action": { "flow": "seo-triple-threat" },
      "scope": "conversation",
      "priority": 6,
      "cooldown_seconds": 300,
    },
    {
      "id": "ai-search-work",
      "condition": { "or": [{ "keywords": ["ai search", "chatgpt answers", "perplexity", "ai overview", "answer engine"] }] },
      "action": { "command": "aeo-optimize" },
      "scope": "conversation",
      "priority": 7,
      "cooldown_seconds": 300,
    },
    {
      "id": "shopify-work",
      "condition": { "or": [{ "file_glob": "**/*.liquid" }, { "keywords": ["shopify", "liquid section", "dawn theme", "shopify store"] }] },
      "action": { "flow": "shopify-full-division" },
      "scope": "conversation",
      "priority": 8,
      "cooldown_seconds": 60,
    },
    {
      "id": "wordpress-work",
      "condition": { "or": [{ "file_glob": "**/functions.php" }, { "file_glob": "**/block.json" }, { "keywords": ["wordpress", "gutenberg", "woocommerce", "wp-cli"] }] },
      "action": { "flow": "wordpress-full-division" },
      "scope": "conversation",
      "priority": 8,
      "cooldown_seconds": 60,
    },
    {
      "id": "react-component",
      "condition": { "or": [{ "keywords": ["react component", "new component", "tsx component"] }, { "file_glob": "**/*.tsx" }] },
      "action": { "flow": "react-component-build" },
      "scope": "conversation",
      "priority": 6,
      "cooldown_seconds": 60,
    },
    {
      "id": "api-design",
      "condition": { "or": [{ "keywords": ["api design", "openapi", "swagger", "create endpoint", "route handler"] }] },
      "action": { "command": "api-spec" },
      "scope": "conversation",
      "priority": 7,
      "cooldown_seconds": 60,
    },
    {
      "id": "brand-work",
      "condition": { "or": [{ "keywords": ["brand", "identity", "logo", "tagline", "voice guide", "brand kit"] }] },
      "action": { "command": "brand-kit" },
      "scope": "conversation",
      "priority": 6,
      "cooldown_seconds": 180,
    },
    {
      "id": "paid-media",
      "condition": { "or": [{ "keywords": ["ads", "meta ads", "google ads", "tiktok ads", "roas", "paid media", "campaign"] }] },
      "action": { "command": "ad-creative" },
      "scope": "conversation",
      "priority": 6,
      "cooldown_seconds": 180,
    },
    {
      "id": "performance-issue",
      "condition": { "or": [{ "keywords": ["slow", "performance", "lighthouse", "bundle size", "cwv", "lcp", "cls", "inp"] }] },
      "action": { "command": "perf-report" },
      "scope": "conversation",
      "priority": 7,
      "cooldown_seconds": 120,
    },
    {
      "id": "security-review",
      "condition": { "or": [{ "keywords": ["security", "vulnerability", "auth", "jwt", "password", "secret"] }, { "file_glob": "**/auth/**/*.ts" }] },
      "action": { "agent": "security-specialist" },
      "scope": "conversation",
      "priority": 10,
      "cooldown_seconds": 0,
    },
    {
      "id": "content-brief",
      "condition": { "or": [{ "keywords": ["keyword research", "content brief", "topic cluster", "seo article"] }] },
      "action": { "command": "content-brief" },
      "scope": "conversation",
      "priority": 6,
      "cooldown_seconds": 180,
    },
    {
      "id": "session-learn",
      "condition": { "event": "session_end" },
      "action": { "command": "learn" },
      "scope": "workspace",
      "priority": 5,
      "cooldown_seconds": 0,
    },
    {
      "id": "output-cleanup",
      "condition": { "event": "before_final_output" },
      "action": { "flow": "output-cleanup" },
      "scope": "conversation",
      "priority": 1,
      "cooldown_seconds": 0,
    },
  ],
  "flows": {
    "github-issue-triage": {
      "parallel": ["triage", "duplicate-pr"],
    },
    "github-pr-review": {
      "parallel": ["duplicate-pr"],
      "sequential_after": ["translate"],
    },
    "seo-triple-threat": {
      "parallel": ["seo-specialist", "aeo-specialist", "geo-specialist", "local-seo-specialist"],
      "aggregate_with": "reporter",
    },
    "shopify-full-division": {
      "parallel": ["shopify-theme-specialist", "shopify-section-builder", "shopify-seo-optimizer", "shopify-analytics-specialist"],
      "aggregate_with": "reporter",
    },
    "wordpress-full-division": {
      "parallel": ["wordpress-theme-developer", "wordpress-section-builder", "wordpress-performance-seo"],
      "aggregate_with": "reporter",
    },
    "react-component-build": {
      "parallel": ["react-specialist", "typescript-specialist", "ui-designer", "accessibility-specialist"],
      "sequential_after": ["testing-frontend"],
      "aggregate_with": "reporter",
    },
    "shopify-full-deployment": {
      "parallel": ["shopify-theme-specialist", "shopify-section-builder", "shopify-seo-optimizer", "shopify-analytics-specialist", "media-buyer", "analytics-specialist"],
      "aggregate_with": "reporter",
    },
    "wordpress-brand-site": {
      "parallel": ["wordpress-theme-developer", "wordpress-section-builder", "wordpress-plugin-developer", "brand-strategist", "brand-identity-generator", "copywriter", "seo-specialist", "content-seo-writer", "local-seo-specialist"],
      "aggregate_with": "reporter",
    },
    "full-saas-build": {
      "parallel": ["react-specialist", "ui-designer", "typescript-specialist", "supabase-specialist", "api-architect", "database-architect", "brand-strategist", "brand-identity-generator", "copywriter", "seo-specialist", "aeo-specialist", "content-seo-writer", "devops-specialist", "security-specialist"],
      "aggregate_with": "reporter",
    },
    "output-cleanup": {
      "sequential": ["rmslop", "spellcheck"],
    },
  },
  "tools": {
    "github-triage": false,
    "github-pr-search": false,
    "seo-audit": false,
    "schema-validator": false,
    "figma-fetch": false,
    "shopify-graphql": false,
    "wp-cli-runner": false,
    "keyword-research": false,
    "brand-color-gen": false,
    "meta-ads-reporter": false,
    "ga4-reporter": false,
    "lighthouse-runner": false,
  },
}
